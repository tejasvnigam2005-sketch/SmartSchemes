# Server
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart_schemes?retryWrites=true&w=majority

# JWT secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS (set to your Vercel domain in production)
FRONTEND_URL=https://smartschemes.vercel.app
